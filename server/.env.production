# ================================================
# Geo-Hotnews 生产环境配置
# ================================================

# 数据库 - PostgreSQL
DATABASE_URL="postgresql://geoadmin:geo_password@localhost:5432/geohotnews?schema=public"

# 服务器配置
PORT=3001
CLIENT_URL=https://ai.zjsifan.com

# JWT Secret
JWT_SECRET=your-production-jwt-secret-change-this-in-production

# OpenRouter AI (必需)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Twitter API (可选)
TWITTER_API_KEY=your-twitter-api-key

# 邮件通知 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=notify@example.com

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=魔法超人
ALIYUN_SMS_TEMPLATE_CODE=SMS_505625119
